{
  "name": "goblin-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Goblin Assistant Next.js frontend",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "test": "TMPDIR=/tmp jest --coverage",
    "test:coverage": "TMPDIR=/tmp jest --coverage",
    "test:unit": "TMPDIR=/tmp jest --coverage",
    "test:watch": "TMPDIR=/tmp jest --watch",
    "test:ci": "TMPDIR=/tmp jest --coverage --ci --maxWorkers=2",
    "test:e2e": "TMPDIR=/tmp playwright test",
    "guard:no-client-v1": "node scripts/guard-no-client-v1.js",
    "security:audit": "npm audit --audit-level moderate",
    "security:audit:python": "../.venv/bin/python -m pip_audit -r requirements.txt",
    "security:audit-ci": "npx audit-ci --moderate",
    "validate-env": "tsx src/config/env.ts"
  },
  "dependencies": {
    "@datadog/browser-logs": "^5.0.0",
    "@datadog/browser-rum": "^5.0.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.8",
    "@sentry/react": "^8.55.0",
    "@tanstack/query-core": "^5.90.12",
    "@tanstack/react-query": "^5.90.12",
    "@vercel/analytics": "^1.6.1",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "highlight.js": "^11.11.1",
    "lottie-react": "^2.4.0",
    "lucide-react": "^0.469.0",
    "next": "15.3.9",
    "posthog-js": "^1.302.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.4.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.49.1",
    "@radix-ui/react-select": "^2.2.6",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.11.0",
    "@types/react": "18.3.1",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "cross-fetch": "^4.1.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.10",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.4",
    "openapi-typescript": "^7.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.7.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "web-streams-polyfill": "^4.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "npm run type-check"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "marked": "^14.1.0",
    "esbuild": "^0.25.0",
    "next": "15.3.9",
    "minimatch": "^10.0.3",
    "ajv": "^8.17.1",
    "diff": "^7.0.0",
    "dompurify": "^3.3.2",
    "@tootallnate/once": "^3.0.1",
    "got": ">=11.8.5",
    "cross-spawn": "^7.0.5",
    "semver": "^7.6.3",
    "micromatch": "^4.0.8",
    "braces": "^3.0.3"
  }
}
