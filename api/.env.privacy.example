# Goblin Assistant - Privacy Configuration
# Copy to .env and fill in your values

# Redis for rate limiting
REDIS_URL=redis://localhost:6379
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Supabase (with RLS enabled)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # Store in Bitwarden!

# Chroma Vector Store
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_DEFAULT_TTL_HOURS=24

# Datadog (production only)
DD_AGENT_HOST=localhost
DD_DOGSTATSD_PORT=8125
DD_SERVICE=goblin-assistant
DD_ENV=production
DD_VERSION=2.0.0

# Privacy settings
ENABLE_PII_DETECTION=true
ENABLE_SANITIZATION=true
ENABLE_RATE_LIMITING=true
CONVERSATION_TTL_HOURS=1
ENABLE_TELEMETRY_REDACTION=true

# Cloudflare Worker (if applicable)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_KV_NAMESPACE_ID=your-kv-namespace-id

# Security
ALLOWED_ORIGINS=https://goblin.fuaad.ai,http://localhost:3000
JWT_SECRET=your-jwt-secret-here  # Store in Bitwarden!
