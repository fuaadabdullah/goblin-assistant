# Terraform Variables Example
# 
# INSTRUCTIONS:
# 1. Copy this file to terraform.tfvars
# 2. Fill in your actual values
# 3. Add terraform.tfvars to .gitignore
# 4. Never commit terraform.tfvars (it contains secrets!)
#
# For local development:
#   terraform apply -var-file terraform.tfvars
#
# For CI/CD:
#   Use GitHub Secrets instead (see .github/workflows/terraform-*.yml)

# Required: Authentication
render_api_key = "your_render_api_key_here"  # Get from https://dashboard.render.com/account/api-tokens
github_token   = "your_github_token_here"    # Get from GitHub Settings → Developer settings → Personal access tokens

# Required: GitHub Repository
github_owner = "fuaadabdullah"
github_repo  = "goblin-assistant"

# Deployment Configuration
environment    = "production"  # Options: development, staging, production
project_name   = "goblin-assistant"
region         = "oregon"      # Options: oregon, ohio, california
service_plan   = "standard"    # Options: starter, standard, pro, pro_plus
num_instances  = 2

# Application Configuration
app_environment = "production"
log_level       = "info"        # Options: debug, info, warning, error, critical
debug_mode      = false
port            = 8001

# URLs
frontend_url   = "https://goblin-assistant.vercel.app"
backend_url    = "https://goblin-assistant-backend.onrender.com"
allowed_origins = "https://goblin-assistant.vercel.app,https://goblin-assistant-backend.onrender.com"

# Rate Limiting
rate_limit_enabled  = true
rate_limit_requests = 100
rate_limit_window   = 60

# Release Version
release_version = "goblin-assistant@1.0.0"

# Health Check
health_check_path    = "/health"
health_check_timeout = 10

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# 
# Currently using Supabase (based on .env.example)
# Get your connection string from Supabase dashboard → Settings → Database → Connection string
#
# For Postgres driver (asyncpg):
# postgresql+asyncpg://postgres:password@host:5433/postgres

database_url = "postgresql+asyncpg://postgres:your_password@db.your_project.supabase.co:5433/postgres"

# ============================================================================
# CACHE CONFIGURATION (Redis)
# ============================================================================
#
# Options:
# 1. Docker Compose (development): "redis://localhost:6379/0"
# 2. Render Redis: "redis://your-render-redis-url:10000"
# 3. External Redis: "redis://host:port/db"

redis_url = "redis://localhost:6379/0"

# ============================================================================
# MONITORING & ERROR TRACKING
# ============================================================================

sentry_dsn                   = "your_sentry_dsn_here"  # Get from https://sentry.io
sentry_traces_sample_rate    = 0.1                     # 10% of transactions
sentry_profiles_sample_rate  = 0.01                    # 1% of transactions

# ============================================================================
# API KEYS - LANGUAGE MODELS & AI PROVIDERS
# ============================================================================
# Leave empty string "" if not using a provider

openai_api_key    = ""  # Get from https://platform.openai.com/api-keys
anthropic_api_key = ""  # Get from https://console.anthropic.com
google_ai_api_key = ""  # Get from https://makersuite.google.com/app/apikey

# ============================================================================
# AUTHENTICATION
# ============================================================================

jwt_secret_key = "your_jwt_secret_key_here"  # Generate: openssl rand -hex 32

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from Supabase dashboard → Settings → API

supabase_url              = "https://your-project.supabase.co"
supabase_service_role_key = "your_service_role_key_here"
supabase_anon_key         = "your_anon_key_here"

# ============================================================================
# AWS CONFIGURATION (Optional)
# ============================================================================
# Leave empty if not using AWS services

aws_access_key_id     = ""  # AWS IAM Access Key
aws_secret_access_key = ""  # AWS IAM Secret Key
aws_region            = "us-east-1"

# ============================================================================
# AZURE CONFIGURATION (Optional)
# ============================================================================
# Leave empty if not using Azure services

azure_api_key           = ""  # Azure API Key
azure_openai_endpoint   = ""  # Azure OpenAI Endpoint

# ============================================================================
# GITHUB INTEGRATION
# ============================================================================

use_github_secrets   = true
github_secret_prefix = "RENDER_"

# ============================================================================
# DOCKER IMAGE (Optional)
# ============================================================================
# Leave empty to use default: ghcr.io/{github_owner}/{github_repo}:latest

docker_image_uri = ""

# ============================================================================
# VALIDATION CHECKLIST
# ============================================================================
#
# Before running 'terraform apply', verify:
#
# ✅ Required fields filled:
#    - render_api_key
#    - github_token
#    - github_owner
#    - database_url (if using Supabase)
#    - supabase_* (if using Supabase)
#
# ✅ For production:
#    - environment = "production"
#    - num_instances >= 2
#    - rate_limit_enabled = true
#    - sentry_dsn is set
#
# ✅ URLs are correct:
#    - frontend_url matches Vercel deployment
#    - backend_url matches Render service
#
# ✅ File is added to .gitignore:
#    echo "terraform.tfvars" >> .gitignore
#
# ✅ Secrets are rotated:
#    - JWT_SECRET_KEY generated with openssl
#    - API keys from respective provider dashboards
#    - Database credentials from Supabase
