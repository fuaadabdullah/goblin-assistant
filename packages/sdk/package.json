{
  "name": "@goblin/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/generated/components.d.ts",
      "default": "./dist/generated/components.js"
    },
    "./operations": {
      "types": "./dist/generated/operations.d.ts",
      "default": "./dist/generated/operations.js"
    },
    "./paths": {
      "types": "./dist/generated/paths.d.ts",
      "default": "./dist/generated/paths.js"
    }
  },
  "scripts": {
    "generate": "bash ../../tooling/generators/generate-sdk-client.sh",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  }
}
