# Goblin Assistant API environment example
# Copy to api/.env (local only, never commit secrets)

# Database
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_SUPABASE_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Auth
SECRET_KEY=replace_with_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Core services
REDIS_URL=redis://localhost:6379/0
SENTRY_DSN=

# Datadog APM (DD_API_KEY is secret — set in Render dashboard, never commit)
DD_API_KEY=
DD_SERVICE=goblin-api
DD_ENV=development
DD_SITE=datadoghq.com
DD_TRACE_AGENTLESS=1
DD_TRACE_AGENT_URL=https://trace.agent.datadoghq.com
ENVIRONMENT=development
JIRA_PROVIDER_OPS_WEBHOOK_URL=
JIRA_PROVIDER_OPS_WEBHOOK_SECRET=
JIRA_PROVIDER_OPS_PROJECT_KEY=PROVOPS
JIRA_ENVIRONMENT=development

# AI providers (set only what you use)
OPENAI_API_KEY=sk-REPLACE_ME
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
GROQ_API_KEY=
SILICONEFLOW_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_AI_API_KEY=
DASHSCOPE_API_KEY=
AZURE_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_API_VERSION=2024-05-01-preview
AZURE_DEPLOYMENT_ID=

# Embeddings for semantic retrieval / RAG
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_MAX_INPUT_TOKENS=8000

# Colab Worker (disposable/ngrok-backed)
COLAB_WORKER_ENDPOINT=
COLAB_WORKER_API_KEY=
COLAB_WORKER_HEARTBEAT_ENABLED=true
COLAB_WORKER_HEARTBEAT_INTERVAL_SECONDS=60

# PDF extraction
GOBLIN_PDF_OCR_ENABLED=false
GOBLIN_ATTACHMENT_CONTEXT_MAX_CHUNKS=5
GOBLIN_ATTACHMENT_CONTEXT_MAX_CHARS=5000

# Git tool (git_tool skill)
# Absolute path to the default git repository for git_* tools
GOBLIN_GIT_REPO=

# GitHub tool (github_tool skill)
# Personal access token — omit for read-only public repo access
GITHUB_TOKEN=

# Issue triage — target repo for auto-created bug reports
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Rovo Dev (Goblin Coder) — Atlassian AI coding agent (internal, not user-facing)
# Auth: Bearer base64(email:token) + SSE session protocol
ATLASSIAN_EMAIL=your-atlassian-account@example.com
ATLASSIAN_API_TOKEN=
# Atlassian site Cloud ID — enables Jira context enrichment in Goblin Coder
# Find at: https://<your-site>.atlassian.net/_edge/tenant_info
ATLASSIAN_CLOUD_ID=
# Optional: override MCP endpoint (leave blank for default)
ROVO_DEV_ENDPOINT=

# Error alerts — Slack + Sentry webhook
SLACK_WEBHOOK_URL=
SENTRY_WEBHOOK_SECRET=

# Email alerts (SMTP)
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
