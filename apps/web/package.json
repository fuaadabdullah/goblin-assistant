{
  "name": "@goblin/web",
  "version": "0.2.0",
  "private": true,
  "description": "Goblin Assistant Next.js frontend",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . && node ../../tooling/quality/guard-no-inline-styles.js",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006 -c ./.storybook",
    "build-storybook": "storybook build -c ./.storybook",
    "chromatic": "chromatic --storybook-config-dir ./.storybook --exit-once-uploaded",
    "prepare": "cd ../.. && husky",
    "test": "TMPDIR=/tmp jest --coverage",
    "test:coverage": "TMPDIR=/tmp jest --coverage",
    "test:unit": "TMPDIR=/tmp jest --coverage",
    "test:watch": "TMPDIR=/tmp jest --watch",
    "test:ci": "TMPDIR=/tmp jest --coverage --ci --maxWorkers=2",
    "test:e2e": "TMPDIR=\"/Volumes/GOBLINOS 1/goblin-assistant/.tmp\" playwright test",
    "guard:no-client-v1": "node ../../tooling/quality/guard-no-client-v1.js",
    "security:audit": "npm audit --audit-level moderate",
    "security:audit:python": "../../.venv/bin/python -m pip_audit -r ../api/requirements.txt",
    "security:audit-ci": "npx audit-ci --moderate",
    "validate-env": "tsx src/config/env.ts"
  },
  "dependencies": {
    "@datadog/browser-logs": "^7.2.0",
    "@datadog/browser-rum": "^7.2.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.8",
    "@sentry/react": "^10.55.0",
    "@tanstack/query-core": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@vercel/analytics": "^2.0.1",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "highlight.js": "^11.11.1",
    "lottie-react": "^2.4.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "posthog-js": "^1.376.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "recharts": "^3.4.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14",
    "framer-motion": "^12.40.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.49.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@radix-ui/react-select": "^2.2.6",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-onboarding": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "cross-fetch": "^4.1.0",
    "eslint": "10.4.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^17.0.5",
    "msw": "^2.12.4",
    "openapi-typescript": "^7.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.7.4",
    "chromatic": "^17.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "web-streams-polyfill": "^4.2.0",
    "storybook": "^10.4.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "npm run type-check"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "marked": "^14.1.0",
    "esbuild": "^0.25.0",
    "next": "16.2.6",
    "minimatch": "^10.0.3",
    "diff": "^7.0.0",
    "dompurify": "^3.3.2",
    "@tootallnate/once": "^3.0.1",
    "got": ">=11.8.5",
    "cross-spawn": "^7.0.5",
    "semver": "^7.6.3",
    "micromatch": "^4.0.8",
    "braces": "^3.0.3"
  }
}
