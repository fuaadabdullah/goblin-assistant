# Docker ignore file for Goblin Assistant
# Exclude files and directories that don't need to be in the Docker image

# Version control
.git
.gitignore
.gitattributes

# Python cache and virtual environments
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
.pytest_cache
.mypy_cache
.coverage
htmlcov/
.tox/
.nox/
.venv/
venv/
env/

# Node.js (if any frontend assets)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
*.log

# Documentation and examples
README.md
docs/
examples/
*.md

# Test files (unless needed at runtime)
tests/
test_*.py
*_test.py

# Development tools
scripts/
tools/
.github/
.circleci/

# Local configuration
.env*
.env.local
.env.development
.env.test
.env.production

# Backup files
*.bak
*.backup
*.tmp

# Large data files
data/
models/
vector_db/
chroma_db/

# Temporary files
*.tmp
*.temp
tmp/
temp/

# CI/CD files
.github/
.circleci/
.dockerignore
.dockerfile
Dockerfile*
