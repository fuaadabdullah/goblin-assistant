{
  "name": "goblin-assistant-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Goblin Assistant monorepo workspace",
  "scripts": {
    "dev": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web dev",
    "build": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web build",
    "start": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web start",
    "lint": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web lint",
    "type-check": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web type-check",
    "test": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web test",
    "test:web": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web test",
    "test:api": "cd apps/api && PYTHONPATH=src python3 -m pytest -o \"addopts=\" -v",
    "test:e2e": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web test:e2e",
    "validate-env": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web validate-env",
    "api:dev": "cd apps/api && PYTHONPATH=src uvicorn api.main:app --reload --port 8001",
    "web:dev": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web dev"
  }
}
