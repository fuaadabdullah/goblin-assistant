  "package-manager": "pnpm",
  "levels": {
    "low": true,
    "moderate": true,
    "high": true,
    "critical": true
  },
  "report": {
    "type": "full",
    "path": "reports"
  },
  "allowlist": [
    "GHSA-qx2v-qp2m-jg93|apps__web>next>postcss",
    "GHSA-qx2v-qp2m-jg93|apps__web>@vercel/analytics>next>postcss",
    "GHSA-qx2v-qp2m-jg93|apps__web>@storybook/nextjs-vite>next>postcss",
    "GHSA-qx2v-qp2m-jg93|apps__web>@storybook/nextjs-vite>vite-plugin-storybook-nextjs>next>postcss"
