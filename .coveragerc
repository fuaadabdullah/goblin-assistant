[run]
source = api
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */migrations/*
    */alembic/*
    */venv/*
    */.venv/*
    */__init__.py

[report]
# Exclude lines from coverage
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    class .*\(Protocol\):
    if False:
    if 0:

precision = 2
show_missing = True
skip_covered = False

# Fail if coverage falls below this percentage
fail_under = 70

[html]
directory = htmlcov

[xml]
output = coverage.xml

[report:paths]
source =
    api
