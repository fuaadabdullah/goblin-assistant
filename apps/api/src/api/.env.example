# Goblin Assistant API environment example
# Copy to api/.env (local only, never commit secrets)

# Database
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_SUPABASE_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Auth
SECRET_KEY=replace_with_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Core services
REDIS_URL=redis://localhost:6379/0
SENTRY_DSN=
ENVIRONMENT=development

# AI providers (set only what you use)
OPENAI_API_KEY=sk-REPLACE_ME
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
GROQ_API_KEY=
SILICONEFLOW_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_AI_API_KEY=
DASHSCOPE_API_KEY=
AZURE_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_API_VERSION=2024-05-01-preview
AZURE_DEPLOYMENT_ID=
