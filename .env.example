# Database Configuration
# SQLite (default for development)
DATABASE_URL=sqlite+aiosqlite:///./goblin_assistant.db

# PostgreSQL (for production/staging)
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/goblin_assistant

# Supabase PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.your_project.supabase.co:5433/postgres

# Redis Configuration (for caching and background tasks)
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_KEY=your_api_key_here
PORT=8003

# Backend URL (for frontend API proxy routes)
BACKEND_URL=http://localhost:8004

# Authentication
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Monitoring and Observability
SENTRY_DSN=your_sentry_dsn
# Sentry privacy defaults are enforced in code:
# - send_default_pii=false
# - before_send / before_breadcrumb redaction hooks
# Sampling is environment-aware by default:
# - production: traces=0.1, profiles=0.01
# - non-production: traces=1.0, profiles=1.0
# Optional overrides (0.0-1.0):
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.01
ENVIRONMENT=development
RELEASE_VERSION=goblin-assistant@1.0.0

# Security / Traffic Controls
# Defaults are environment-aware in code:
# - production => RATE_LIMIT_ENABLED defaults to true
# - non-production => RATE_LIMIT_ENABLED defaults to false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Frontend Monitoring (set in Vercel dashboard or .env.local)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Vault Configuration (for secrets management)
VAULT_URL=http://localhost:8200
VAULT_TOKEN=your_vault_token

# Model Configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MAX_INPUT_TOKENS=8000
CONTEXT_RESPONSE_RESERVE_TOKENS=1024
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GROQ_API_KEY=your_groq_api_key
SILICONEFLOW_API_KEY=your_siliconeflow_api_key
GOOGLE_API_KEY=your_google_api_key

# Provider Endpoints (optional overrides)
OPENAI_ENDPOINT=https://api.openai.com/v1
ANTHROPIC_ENDPOINT=https://api.anthropic.com
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com
DEEPSEEK_ENDPOINT=https://api.deepseek.com
GROQ_ENDPOINT=https://api.groq.com/openai/v1
SILICONEFLOW_ENDPOINT=https://api.siliconflow.com
TOGETHER_ENDPOINT=https://api.together.xyz
REPLICATE_ENDPOINT=https://api.replicate.com
HUGGINGFACE_ENDPOINT=https://api-inference.huggingface.co
COHERE_ENDPOINT=https://api.cohere.ai

# GCP Vertex AI
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_json
GCP_ACCESS_TOKEN=your_gcp_access_token_optional

# Aliyun DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_ENDPOINT=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Azure OpenAI
AZURE_API_KEY=your_azure_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_API_VERSION=2024-05-01-preview
AZURE_DEPLOYMENT_ID=gpt-4o-mini

# Vertex AI endpoint override (optional)
VERTEX_AI_ENDPOINT=https://generativelanguage.googleapis.com

# Local LLM Deployments
OLLAMA_GCP_URL=http://34.60.255.199:11434
LLAMACPP_GCP_URL=http://34.132.226.143:8000
OLLAMA_KAMATERA_ENDPOINT=http://192.175.23.150:8002
KAMATERA_LLAMACPP_ENDPOINT=http://45.61.51.220:8000
LOCAL_LLM_API_KEY=your_local_llm_api_key

# Environment
ENVIRONMENT=development
DEBUG=true

# Sandbox Configuration (secure code execution)
SANDBOX_ENABLED=false
SANDBOX_IMAGE=ghcr.io/yourorg/sandbox:latest
SANDBOX_RATE_LIMIT_PER_MINUTE=10
SANDBOX_RATE_LIMIT_PER_HOUR=100
JOBS_DIR=/var/lib/goblin/sandbox_jobs
COSIGN_PUBLIC_KEY_PATH=/etc/sandbox/cosign.pub
MAX_JOB_MEMORY=256m
MAX_JOB_CPUS=0.25
JOB_TIMEOUT_SECONDS=10
S3_BUCKET=goblin-sandbox