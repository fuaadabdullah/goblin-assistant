{
  "bucket": "contract",
  "description": "Cross-layer contract guarantees for API envelopes/routes, engine pillars, and web consumers.",
  "paths": [
    "apps/api/src/api/tests/test_contract_boundaries.py",
    "apps/api/src/api/tests/test_chat_route_version_aliases.py",
    "tests/contract/test_engine_routing_contract.py",
    "tests/contract/test_engine_memory_contract.py",
    "tests/contract/test_engine_sandbox_contract.py",
    "tests/contract/test_engine_auth_contract.py",
    "tests/contract/test_engine_observability_contract.py",
    "apps/web/src/api/__tests__/apiClient.contract.test.ts"
  ],
  "commands": [
    {
      "name": "api-contract-suite",
      "run": "cd apps/api && PYTHONPATH=src python3.11 -m pytest -o \"addopts=\" -v src/api/tests/test_contract_boundaries.py src/api/tests/test_chat_route_version_aliases.py"
    },
    {
      "name": "engine-routing-contract-suite",
      "run": "cd apps/api && PYTHONPATH=src python3.11 -m pytest -o \"addopts=\" -v ../../tests/contract/test_engine_routing_contract.py"
    },
    {
      "name": "engine-memory-contract-suite",
      "run": "cd apps/api && PYTHONPATH=src python3.11 -m pytest -o \"addopts=\" -v ../../tests/contract/test_engine_memory_contract.py"
    },
    {
      "name": "engine-sandbox-contract-suite",
      "run": "cd apps/api && PYTHONPATH=src python3.11 -m pytest -o \"addopts=\" -v ../../tests/contract/test_engine_sandbox_contract.py"
    },
    {
      "name": "engine-auth-contract-suite",
      "run": "cd apps/api && PYTHONPATH=src python3.11 -m pytest -o \"addopts=\" -v ../../tests/contract/test_engine_auth_contract.py"
    },
    {
      "name": "engine-observability-contract-suite",
      "run": "cd apps/api && PYTHONPATH=src python3.11 -m pytest -o \"addopts=\" -v ../../tests/contract/test_engine_observability_contract.py"
    },
    {
      "name": "web-consumer-contract-suite",
      "run": "mkdir -p .tmp && TMPDIR=\"$PWD/.tmp\" pnpm --filter @goblin/web exec jest --runInBand --coverage=false src/api/__tests__/apiClient.contract.test.ts"
    }
  ]
}
