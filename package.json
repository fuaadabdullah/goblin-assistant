{
  "name": "goblin-assistant",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "generate-types": "openapi-typescript http://localhost:8001/openapi.json --output src/types/generated.ts",
    "validate-env": "tsx scripts/validate-env.ts",
    "validate-supabase": "node validate-supabase.js",
    "test-auth": "node test-auth.js",
    "test-workflow": "node test-complete-workflow.js",
    "security:audit": "npm audit --audit-level moderate || true",
    "security:audit-ci": "audit-ci --config audit-ci.json",
    "security:audit-html": "echo 'HTML audit report disabled - npm-audit-html removed due to vulnerabilities' && npm audit --json > reports/security-audit.json || true",
    "security:scan": "npm run security:audit && npm run security:audit-html",
    "setup": "node scripts/setup.js",
    "quality:check": "npm run lint || echo 'ESLint failed, continuing...' && npm run type-check || echo 'Type check failed, continuing...' && npm run security:audit",
    "quality:fix": "npm run lint:fix",
    "metrics": "node scripts/quality-metrics.js",
    "quality:report": "npm run lint || echo 'ESLint failed, continuing...' && npm run metrics",
    "storybook": "storybook dev -p 6006",
    "prepare": "husky",
    "build-storybook": "storybook build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@datadog/browser-logs": "^6.25.1",
    "@datadog/browser-rum": "^6.25.1",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/node": "^10.29.0",
    "@sentry/react": "^10.29.0",
    "@supabase/supabase-js": "^2.87.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@vercel/analytics": "^1.6.1",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.469.0",
    "next-intl": "^4.7.0",
    "openai": "^6.10.0",
    "posthog-js": "^1.302.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "sonner": "^1.4.41",
    "react-router-dom": "^7.10.0",
    "next": "^15.5.9",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.40.1",
    "@storybook/addon-docs": "^10.1.8",
    "@storybook/addon-onboarding": "^10.1.8",
    "@tanstack/react-query": "^5.90.12",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^4.2.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/user-event": "^14.5.0",
    "@vitest/coverage-v8": "^1.0.0",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.4.20",
    "cross-fetch": "^4.1.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^23.0.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.4",
    "openapi-typescript": "^7.0.0",
    "playwright": "^1.57.0",
    "postcss": "^8.4.49",
    "prettier": "^3.7.4",
    "sharp": "^0.34.5",
    "storybook": "^10.1.8",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "web-streams-polyfill": "^4.2.0",
    "vitest": "^1.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "npm run type-check"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "marked": "^14.1.0",
    "esbuild": "^0.25.0",
    "got": ">=11.8.5",
    "cross-spawn": "^7.0.5",
    "semver": "^7.6.3",
    "micromatch": "^4.0.8",
    "braces": "^3.0.3"
  }
}